    <panel id="version" title="Your Version">
      <line data="version" />
      <line data="channel" />
    </panel>
    <panel id="wiki" title="Wiki &amp; JIRA">
      <line>Need Help? Try the Wiki</line>
      <line>Found a bug? Let us know</line>
    </panel>
    <panel id="grid" title="Grid Status">
      <line data="grid_status" />
      <line data="grid_in_world" />
      <line data="sl_time" />
    </panel>
    <panel id="status-updates" title="">
      <line data="status_updates" />
    </panel>
  </panels>

  <latestVersion source="https://phoenixviewer.com/app/loginV3/fs-versions.json" branch="display" grid="sl" platform="win" variant="regular" fallback="7.2.4 (80712)" refreshSeconds="3600" />

  <gridStatus source="https://phoenixviewer.com/app/loginV3/secondlife.xml" refreshSeconds="300" fallbackStatus="Online" fallbackInWorld="34,829" />
  <statusUpdates source="https://status.secondlifegrid.net/history.rss" limit="3" refreshSeconds="600" />

  <feeds>
    <feed id="wavebreaker-blog" title="Wavebreaker Blog" type="rss" url="https://www.wavebreakerviewer.org/feed/" link="https://www.wavebreakerviewer.org/" limit="3" />
    <feed id="linden-news" title="Linden News" type="rss" url="https://community.secondlife.com/rss/1-blog-rss.xml" link="https://community.secondlife.com/blogs/" limit="3" />
    <feed id="blogger-network" title="Blogger Network" type="categories" url="https://community.secondlife.com/rss/9-community-news.xml" link="https://community.secondlife.com/blogs/" limit="3">
