      <category label="Bloggers" url="https://community.secondlife.com/blogs/" />
      <category label="Videos" url="https://community.secondlife.com/blogs/" />
      <category label="Fashion" url="https://community.secondlife.com/blogs/" />
      <category label="Décor" url="https://community.secondlife.com/blogs/" />
      <category label="Destinations" url="https://community.secondlife.com/blogs/" />
    </feed>
  </feeds>

  <destinations title="Destinations" sourceBase="https://phoenixviewer.com/app/loginV3/xml_dest_" sourceSuffix=".json" limit="24">
    <tab id="new" label="Recent" />
    <tab id="popular" label="Popular" />
    <tab id="events" label="Featured" />
    <tab id="editor" label="Editors' Picks" />
