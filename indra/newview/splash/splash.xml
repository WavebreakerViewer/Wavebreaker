<?xml version="1.0" encoding="UTF-8"?>
<splash title="Wavebreaker" theme="dark">
  <branding>
    <name>Wavebreaker</name>
    <tagline></tagline>
    <logo>wavebreaker_logo.png</logo>
    <smallLogo>wavebreaker_icon.png</smallLogo>
    <backgroundColor>#202020</backgroundColor>
    <accentColor>#1f9bd1</accentColor>
    <textColor>#ffffff</textColor>
  </branding>

  <links>
    <wiki label="Wiki" url="https://wiki.wavebreakerviewer.org/" />
    <jira label="JIRA" url="https://jira.secondlife.com/" />
    <help label="Help" url="https://wiki.wavebreakerviewer.org/wavebreaker_troubleshooting" />
  </links>

  <panels>
    <panel id="latest" title="Latest Version">
      <line data="latest_version" />
